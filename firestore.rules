rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isAuthenticated() && request.auth.uid == userId; 
    }
    
    function isAdmin() { 
      return isAuthenticated() && 
        request.auth.token != null && 
        'email' in request.auth.token && (
          request.auth.token.email == 'darshjain@gmail.com' ||
          request.auth.token.email == 'pratyushpatwal@gmail.com' ||
          request.auth.token.email == 'pratyushpatwal7629@gmail.com'
        ); 
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /appointments/{appointmentId} {
      // Allow creation if authenticated and either the record's userId matches the authenticating user, or the user is an admin
      allow create: if isAuthenticated() && (
        !('userId' in request.resource.data) || 
        request.resource.data.userId == request.auth.uid || 
        isAdmin()
      );

      // Safe check to avoid rule crashes when scanning documents that might be missing the 'userId' field
      allow read, update, delete: if isAuthenticated() && (
        !('userId' in resource.data) || 
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }

    // Support bookings collection path as well, ensuring absolute safety for both names
    match /bookings/{bookingId} {
      allow create: if isAuthenticated() && (
        !('userId' in request.resource.data) || 
        request.resource.data.userId == request.auth.uid || 
        isAdmin()
      );

      allow read, update, delete: if isAuthenticated() && (
        !('userId' in resource.data) || 
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }
  }
}
